{
  "Docs": {
    "OpenApiBaseUrl": "http://localhost:2933/swagger/index.html"
  },
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "alphabet-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "hubs": {
        "ClusterId": "alphabet-api",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "health": {
        "ClusterId": "alphabet-api",
        "Match": {
          "Path": "/health"
        }
      }
    },
    "Clusters": {
      "alphabet-api": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:2933/swagger/index.html"
          }
        }
      }
    }
  }
}
